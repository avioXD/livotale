# Production Docker Compose environment (project: livotale-prod)
# Copy to .env.production in the repo root (gitignored).
# Usage: docker compose --env-file .env.production up -d --build

COMPOSE_PROJECT_NAME=livotale-prod

# --- Database ---
POSTGRES_USER=livotale_user
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=livotale_prod

# --- API core ---
JWT_SECRET=change-me-to-a-long-random-secret
INTERNAL_NOTIFICATIONS_KEY=change-me-internal-notifications-key
CORS_ORIGINS=https://your-domain.example

# --- Object storage (real S3; no LocalStack) ---
S3_BUCKET=your-bucket-name
S3_REGION=ap-south-1
S3_KEY_PREFIX=livotale
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me

# --- Daily database backups to S3 ---
# Uploaded as s3://$S3_BUCKET/backub/YYYY/MM/DD/YYYYMMDDTHHMMSSZ/livotale_prod_YYYYMMDDTHHMMSSZ.sql.gz
S3_BACKUP_PREFIX=backub
DB_BACKUP_CRON="0 2 * * *"
RUN_BACKUP_ON_STARTUP=false
TZ=UTC

# --- Optional encryption keys (integrations UI / bank details) ---
# INTEGRATIONS_ENCRYPTION_KEY=
# BANK_DETAILS_ENCRYPTION_KEY=

# --- Optional Twilio / SendGrid / AI (or configure in Admin → Integrations) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_PARENT_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
# TWILIO_VERIFY_SERVICE_SID=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Livotale
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_MODEL=
# AI_BASE_URL=

# --- Gateway ---
HTTP_PORT=8080
VITE_API_BASE_URL=/api/v1

# --- Optional ---
# NOTIFICATION_TEST_PHONE_ALLOWLIST=+10000000000
# JWT_EXPIRES_IN=8h
# API_AUDIT_LOGGING=true
