# Livotale UI — host development template
# Copy to apps/ui/.env when running Vite on your machine (pnpm dev).
#
# Docker Compose does NOT load this file via env_file.
# Dev containers: docker-compose.dev.yml inline env
# Prod containers: docker-compose.yml build args + nginx gateway
#   VITE_API_BASE_URL=http://localhost:3008/api/v1
#   VITE_HMR_CLIENT_PORT=3008
#   VITE_APP_ENV=dev

# --- Through Docker nginx gateway (recommended with docker compose up ui nginx) ---
VITE_API_BASE_URL=http://localhost:3008/api/v1
VITE_HMR_CLIENT_PORT=3008

# --- Direct host API (when API runs locally without nginx) ---
# VITE_API_BASE_URL=http://localhost:4000/api/v1
# Unset VITE_HMR_CLIENT_PORT when not using the nginx gateway.

# --- Local development defaults ---
VITE_APP_ENV=dev

