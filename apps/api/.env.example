# Livotale API — host development template
# Copy to apps/api/.env when running the API on your machine (uv run dev).
#
# Docker Compose does NOT load this file via env_file.
# Dev containers: docker-compose.dev.yml inline env
# Prod containers: docker-compose.yml + repo-root .env.production
#   api, worker → DATABASE_URL, REDIS_URL, JWT_SECRET, S3_*, CORS_ORIGINS, …
#   ui          → VITE_API_BASE_URL, VITE_HMR_CLIENT_PORT, VITE_APP_ENV
#
# Note: api/worker mount ./apps/api, so a local apps/api/.env can still be read
# by Pydantic for keys not set in docker-compose. Keep secrets only in .env
# (gitignored), not in this example file.

# --- Core (required for host dev) ---
APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://livotale_user:password@localhost:5433/livotale
REDIS_URL=redis://localhost:6381
JWT_SECRET=change-me-to-a-long-random-secret
CORS_ORIGINS=http://localhost:3008,http://localhost:5174,http://localhost:5173,http://localhost:4000

# --- Server (optional; uv run dev defaults to 0.0.0.0:4000) ---
# HOST=0.0.0.0
# PORT=4000

# --- Local development defaults ---
JWT_EXPIRES_IN=8h
JWT_ISSUER=livotale-api
SEED_PACKAGES_ON_STARTUP=true
API_AUDIT_LOGGING=false
RATE_LIMIT_ENABLED=true
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
INTERNAL_NOTIFICATIONS_KEY=change-me-local-internal-notifications-key
NOTIFICATION_TEST_PHONE_ALLOWLIST=+10000000000

# --- S3-compatible file storage (LocalStack on host) ---
S3_BUCKET=livotale-files
S3_REGION=ap-south-1
S3_KEY_PREFIX=livotale
S3_ENDPOINT=http://localhost:4567
S3_PUBLIC_ENDPOINT=http://localhost:4567
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Twilio (optional; env-sourced integrations) ---
# Set source to "Environment" in Admin → Integrations before using these.
# API Key auth: TWILIO_ACCOUNT_SID=SK..., TWILIO_AUTH_TOKEN=<secret>,
# TWILIO_PARENT_ACCOUNT_SID=AC...
# TWILIO_ACCOUNT_SID=
# TWILIO_PARENT_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
# TWILIO_VERIFY_SERVICE_SID=

# --- SendGrid (optional) ---
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Livotale

# --- AI extraction (optional) ---
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_MODEL=
# AI_BASE_URL=

# --- Encrypted settings (optional) ---
# Generate 32-byte URL-safe base64 values:
# python - <<'PY'
# import base64, os
# print(base64.urlsafe_b64encode(os.urandom(32)).decode())
# PY
# INTEGRATIONS_ENCRYPTION_KEY=
# BANK_DETAILS_ENCRYPTION_KEY=

# APP_ENV=dev → demo OTP (123456) + dummy Twilio/SendGrid.
# APP_ENV=production → live provider calls (use with care locally).
