# FastAPI Livotale API — environment template

APP_ENV=development
DATABASE_URL=postgresql+asyncpg://livotale_user:password@localhost:5433/livotale
REDIS_URL=redis://localhost:6379
JWT_SECRET=livotale-development-jwt-secret-change-me
JWT_EXPIRES_IN=8h
JWT_ISSUER=livotale-api
HOST=0.0.0.0
PORT=4001
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
S3_BUCKET=amzn-bucket-livotale-v1-544559210654-us-east-1-an
S3_REGION=us-east-1
S3_KEY_PREFIX=livotale
# S3_ENDPOINT=http://localhost:4566  # LocalStack only — omit for real AWS
# S3_PUBLIC_ENDPOINT=http://localhost:4567  # Browser-reachable URL when S3_ENDPOINT is internal (e.g. Docker localstack:4566)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
INTEGRATIONS_MODE=dummy
OTP_MODE=demo
SEED_PACKAGES_ON_STARTUP=true
INTERNAL_NOTIFICATIONS_KEY=replace-with-internal-key
INTEGRATIONS_ENCRYPTION_KEY=replace-with-32-byte-base64-key
NOTIFICATION_TEST_PHONE_ALLOWLIST=+917001638349